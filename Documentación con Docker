2) Archivos de UBU2 (python http.server)

mkdir -p ubu2
cat > ubu2/Dockerfile <<'EOF'
FROM python:3.11-slim
WORKDIR /app
RUN printf '%s\n' \
  '<h1>Hola desde UBU2 (contenedor ubu2)</h1>' \
  '<p>Servido por python -m http.server 8080</p>' \
  > /app/index.html
EXPOSE 8080
CMD ["python","-m","http.server","8080","--bind","0.0.0.0"]
EOF

3) Archivos de UBU1 (nginx + HTTPS + proxy a ubu2)

Config nginx ubu1/default.conf:
mkdir -p ubu1
cat > ubu1/default.conf <<'EOF'
server {
  listen 443 ssl;
  server_name _;

  ssl_certificate     /etc/nginx/ssl/self.crt;
  ssl_certificate_key /etc/nginx/ssl/self.key;

  location / {
    proxy_pass http://ubu2:8080;
  }
}
EOF

Dockerfile ubu1/Dockerfile (genera certificado dentro del contenedor):
cat > ubu1/Dockerfile <<'EOF'
FROM nginx:alpine
RUN apk add --no-cache openssl
COPY default.conf /etc/nginx/conf.d/default.conf

RUN mkdir -p /etc/nginx/ssl && \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
      -keyout /etc/nginx/ssl/self.key \
      -out /etc/nginx/ssl/self.crt \
      -subj "/CN=ubu1"

EXPOSE 443
EOF

4) Vagrantfile

cat > Vagrantfile <<'EOF'
Vagrant.configure("2") do |config|
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.trigger.before [:up] do |t|
    t.run = { inline: "bash -lc 'docker network inspect lab-net >/dev/null 2>&1 || docker network create lab-net'" }
  end

  config.vm.define "ubu2" do |ubu2|
    ubu2.vm.provider "docker" do |d|
      d.build_dir = "ubu2"
      d.name = "ubu2"
      d.create_args = ["--network", "lab-net"]
      d.ports = ["8080:8080"]
      d.vagrant_vagrantfile = false
    end
  end

  config.vm.define "ubu1" do |ubu1|
    ubu1.vm.provider "docker" do |d|
      d.build_dir = "ubu1"
      d.name = "ubu1"
      d.create_args = ["--network", "lab-net"]
      d.ports = ["8443:443"]
      d.vagrant_vagrantfile = false
    end
  end
end

